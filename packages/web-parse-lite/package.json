{
  "name": "web-parse-lite",
  "version": "1.0.0",
  "description": "Lightweight HTML parser for extracting content from web pages using CSS selectors",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
